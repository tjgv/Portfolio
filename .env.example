# Copy to .env and fill in. Used by the workflow API server (npm run server).

# Discord: get token from Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=

# Gmail (for "New email received" trigger): create OAuth 2.0 Client ID (Web) in Google Cloud Console.
# Add redirect URI: http://localhost:3001/api/auth/gmail/callback
# Enable Gmail API for the project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5177
